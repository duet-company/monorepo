{
  "name": "duet-company-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "Duet Company - AI-first data infrastructure platform",
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "dev": "bun run --filter './apps/*' dev",
    "build": "bun run build:packages && bun run build:apps",
    "build:packages": "bun run --filter './packages/*' build",
    "build:apps": "bun run --filter './apps/*' build",
    "test": "bun run --filter './**/*' test",
    "lint": "bun run --filter './**/*' lint",
    "typecheck": "bun run --filter './**/*' typecheck",
    "deploy": "bun run scripts/deploy.sh",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\""
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "prettier": "^3.2.0",
    "turbo": "^1.12.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "bun": ">=1.0.0"
  },
  "packageManager": "bun@1.0.0"
}
